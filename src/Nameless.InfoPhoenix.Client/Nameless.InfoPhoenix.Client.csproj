<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<RootNamespace>Nameless.InfoPhoenix.Client</RootNamespace>
		<ApplicationManifest>App.manifest</ApplicationManifest>
		<ApplicationIcon>Resources\info_phoenix_icon.ico</ApplicationIcon>
		<OutputType>WinExe</OutputType>
		<UseWPF>true</UseWPF>
		<RuntimeIdentifiers>win-x64</RuntimeIdentifiers>
		<TargetFramework>net6.0-windows</TargetFramework>
		<ImplicitUsings>enable</ImplicitUsings>
		<Nullable>enable</Nullable>
		<LangVersion>latest</LangVersion>
		<BaseOutputPath>..\..\bin</BaseOutputPath>
	</PropertyGroup>

	<ItemGroup>
		<None Remove="AppSettings.json" />
		<None Remove="Resources\docx_file_icon.png" />
		<None Remove="Resources\doc_file_icon.png" />
		<None Remove="Resources\info_phoenix_icon.png" />
		<None Remove="Resources\info_phoenix_splash_screen.png" />
		<None Remove="Resources\rtf_file_icon.png" />
	</ItemGroup>

	<ItemGroup>
	  <Page Remove="Resources\OverrideResourceDictionary.xaml" />
	  <Page Remove="Resources\ValidationResourceDictionary.xaml" />
	</ItemGroup>

	<ItemGroup>
		<PackageReference Include="Microsoft.EntityFrameworkCore.Tools" Version="7.0.18">
			<PrivateAssets>all</PrivateAssets>
			<IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
		</PackageReference>
		<PackageReference Include="Microsoft.Extensions.Hosting.Abstractions" Version="8.0.0" />
		<PackageReference Include="NLog.Extensions.Logging" Version="5.3.11" />
		<PackageReference Include="Ookii.Dialogs.Wpf" Version="5.0.1" />
		<PackageReference Include="WPF-UI" Version="3.0.4" />
	</ItemGroup>

	<ItemGroup>
		<ProjectReference Include="..\Nameless.InfoPhoenix.Core\Nameless.InfoPhoenix.Core.csproj" />
		<ProjectReference Include="..\Nameless.InfoPhoenix.Domain\Nameless.InfoPhoenix.Domain.csproj" />
		<ProjectReference Include="..\Nameless.InfoPhoenix.Office\Nameless.InfoPhoenix.Office.csproj" />
		<ProjectReference Include="..\Nameless.InfoPhoenix.UI\Nameless.InfoPhoenix.UI.csproj" />
	</ItemGroup>

	<ItemGroup>
		<Content Include="AppSettings.json">
		  <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
		</Content>
		<Resource Include="Resources\docx_file_icon.png">
			<CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
		</Resource>
		<Resource Include="Resources\doc_file_icon.png">
			<CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
		</Resource>
		<Resource Include="Resources\info_phoenix_icon.ico">
			<CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
		</Resource>
		<Resource Include="Resources\info_phoenix_icon.png">
		  <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
		</Resource>
		<Resource Include="Resources\rtf_file_icon.png">
			<CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
		</Resource>
	</ItemGroup>

	<ItemGroup>
	  <Resource Include="Resources\OverrideResourceDictionary.xaml">
	    <SubType>Designer</SubType>
	    <Generator>MSBuild:Compile</Generator>
	  </Resource>
	  <Resource Include="Resources\ValidationResourceDictionary.xaml">
	    <SubType>Designer</SubType>
	    <Generator>MSBuild:Compile</Generator>
	  </Resource>
	</ItemGroup>

	<ItemGroup>
		<SplashScreen Include="Resources\info_phoenix_splash_screen.png">
		  <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
		</SplashScreen>
	</ItemGroup>

</Project>
